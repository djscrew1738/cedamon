# =============================================================================
# RedAmon — Environment Configuration Template
# =============================================================================
# Copy this file to `.env` and fill in your secrets BEFORE running
#   docker compose up -d
#
# SECURITY WARNING: Every variable marked [REQUIRED] MUST be changed from its
# default before any production-like deployment. The fallback defaults in
# docker-compose.yml are intentionally weak so that local development works
# out-of-the-box. They MUST NOT be used for shared/staging/production hosts.
#
# Validation: Run `./scripts/check-env.sh` after editing to verify that no
# required secret still uses its default value.
# =============================================================================

# =============================================================================
# [REQUIRED] Core Secrets — Change these first
# =============================================================================

# Shared internal API key used for service-to-service authentication.
# The webapp, agent, recon-orchestrator, and kali-sandbox all verify this key.
# Minimum 32 characters, random alphanumeric.
INTERNAL_API_KEY=changeme

# NextAuth / webapp session encryption secret.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=changeme

# =============================================================================
# [REQUIRED] PostgreSQL Database
# =============================================================================

POSTGRES_USER=redamon
POSTGRES_PASSWORD=redamon_secret
POSTGRES_DB=redamon
POSTGRES_PORT=5432

# =============================================================================
# [REQUIRED] Neo4j Graph Database
# =============================================================================

NEO4J_PASSWORD=changeme123
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# =============================================================================
# [REQUIRED] GVM / OpenVAS Scanner
# =============================================================================

# Default gvmd admin password. The GVM stack auto-creates an "admin" user
# with this password on first boot. Change it afterwards via:
#   docker compose exec -u gvmd gvmd gvmd --user=admin --new-password='<new>'
GVM_PASSWORD=admin

# =============================================================================
# Service Ports — Change if you have collisions on the Docker host
# =============================================================================

WEBAPP_PORT=3000
AGENT_PORT=8090
RECON_ORCH_PORT=8010

# Kali Sandbox MCP server ports (mapped to host for external tool access)
MCP_NETWORK_RECON_PORT=8001
MCP_NUCLEI_PORT=8002
MCP_METASPLOIT_PORT=8003
MCP_NMAP_PORT=8004
MCP_PLAYWRIGHT_PORT=8005

# =============================================================================
# Knowledge Base Embedding Configuration
# =============================================================================
# Controls how the KB generates vector embeddings for ingestion and query.
# When KB_EMBEDDING_USE_API is false (default), the local sentence-transformers
# model runs on CPU/GPU inside the agent container.
#
# IMPORTANT: Ingestion and query MUST use the same embedding model.
# Switching models requires a full KB rebuild:
#   make -C knowledge_base kb-rebuild-lite MODE=docker
# =============================================================================

# Use an external API for KB embedding (ingestion + query)
KB_EMBEDDING_USE_API=false

# API base URL (only used when KB_EMBEDDING_USE_API=true)
# Uses the OpenAI SDK, which works with any OpenAI-compatible API.
# Examples:
#   OpenAI:      https://api.openai.com/v1  (default if left empty)
#   Ollama:      http://host.docker.internal:11434/v1
#   LiteLLM:     http://host.docker.internal:4000/v1
#   Together AI: https://api.together.xyz/v1
#   Azure:       https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   vLLM:        http://host.docker.internal:8000/v1
#   Fireworks:   https://api.fireworks.ai/inference/v1
KB_EMBEDDING_API_BASE_URL=

# API key (only used when KB_EMBEDDING_USE_API=true)
KB_EMBEDDING_API_KEY=

# API model name (only used when KB_EMBEDDING_USE_API=true)
# OpenAI:      text-embedding-3-small (1536 dim), text-embedding-3-large (3072 dim)
# Ollama:      nomic-embed-text, mxbai-embed-large, all-minilm
# Together AI: togethercomputer/m2-bert-80M-8k-retrieval
KB_EMBEDDING_API_MODEL=text-embedding-3-small

# =============================================================================
# Knowledge Base Build & Runtime
# =============================================================================

# Skip heavy KB dependencies (~4.4 GB) during agent image build.
# Set to "true" if you do not plan to use the Knowledge Base.
SKIP_KB=false

# Enable the Knowledge Base at agent runtime.
# When true, the agent can query the local vector DB for tradecraft / CVE intel.
KB_ENABLED=false

# =============================================================================
# Recon API Keys (optional but strongly recommended for high-level OSINT)
# =============================================================================
# Leave empty to use free/limited tiers or skip the enrichment entirely.

# Shodan — host intelligence, open ports, banners, passive CVEs
# Get a key: https://account.shodan.io/
SHODAN_API_KEY=

# URLScan.io — passive URL/subdomain discovery
# Get a key: https://urlscan.io/user/profile/
URLSCAN_API_KEY=

# ProjectDiscovery Chaos — subdomain dataset
# Get a key: https://chaos.projectdiscovery.io/
CHAOS_API_KEY=

# VirusTotal — reputation, passive DNS, subdomain discovery
# Free tier: 4 requests/minute
# Get a key: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Censys — internet asset + certificate intelligence
# Get credentials: https://search.censys.io/account
CENSYS_API_TOKEN=
CENSYS_ORG_ID=

# FOFA — internet asset search
# Get a key: https://en.fofa.info/
FOFA_API_KEY=

# Netlas — internet asset intelligence
# Get a key: https://app.netlas.io/
NETLAS_API_KEY=

# CriminalIP — threat intelligence + asset discovery
# Get a key: https://www.criminalip.io/
CRIMINALIP_API_KEY=

# ZoomEye — cyberspace search
# Get a key: https://www.zoomeye.org/
ZOOMEYE_API_KEY=

# Alienvault OTX — threat intel (free, no key required for basic queries)
OTX_API_KEY=

# ProjectDiscovery Uncover keys (optional)
UNCOVER_HUNTER_API_KEY=
UNCOVER_HUNTERHOW_API_KEY=
UNCOVER_PUBLICWWW_API_KEY=
UNCOVER_QUAKE_API_KEY=
UNCOVER_GOOGLE_API_KEY=
UNCOVER_GOOGLE_API_CX=
UNCOVER_ONYPHE_API_KEY=
UNCOVER_DRIFTNET_API_KEY=

# =============================================================================
# NVD API Key (optional, speeds up NVD ingestion 10x)
# Get a free key: https://nvd.nist.gov/developers/request-an-api-key
# =============================================================================

NVD_API_KEY=

# =============================================================================
# Kali Sandbox Auto-Updates
# =============================================================================

# Automatically update Metasploit modules on container start.
MSF_AUTO_UPDATE=true

# Automatically update Nuclei templates on container start.
NUCLEI_AUTO_UPDATE=true

# =============================================================================
# Build-time Variables
# =============================================================================

# Version string baked into the webapp image at build time.
# Displayed in the UI footer / about dialog.
REDAMON_VERSION=0.0.0
